import com.companion.lol.storage.impl.model.ids.SettingsId;
import com.companion.lol.storage.impl.model.model.OffsetDateTime;

CREATE TABLE UpdatesTable (
  id INTEGER AS SettingsId NOT NULL PRIMARY KEY,
  champion TEXT AS OffsetDateTime,
  rotation TEXT AS OffsetDateTime
);

insert:
INSERT OR REPLACE INTO UpdatesTable VALUES ?;

findAll:
SELECT * FROM UpdatesTable;